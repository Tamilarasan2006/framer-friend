# MongoDB Atlas Connection String
# Get this from MongoDB Atlas Dashboard:
# 1. Click "Cluster" → "Connect"
# 2. Select "Drivers" → "Node.js"
# 3. Copy the connection string
# 4. Replace <username>, <password>, and cluster details with your values
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/farmersfriend?retryWrites=true&w=majority

# Server Port (optional, defaults to 3000)
PORT=3000

# Optional: API Key for government market data
# DATA_GOV_API_KEY=your_api_key_here
